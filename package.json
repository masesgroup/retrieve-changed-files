{
  "name": "retrieve-changed-files",
  "description": "GitHub action that retrieves all changed files in a pull request or push.",
  "version": "4.0.0",
  "private": true,
  "author": "MASES s.r.l. (original author Jitterbit, Inc.)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masesgroup/retrieve-changed-files.git"
  },
  "homepage": "https://github.com/masesgroup/retrieve-changed-files#readme",
  "bugs": {
    "url": "https://github.com/masesgroup/retrieve-changed-files/issues"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "TypeScript",
    "JavaScript",
    "Get",
    "Changed",
    "Modified",
    "Diff",
    "Files"
  ],
  "main": "lib/index.js",
  "engines": {
    "node": ">=24.*.*"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/**/* lib/**/*",
    "format": "prettier --write \"src/**/*.ts\"",
	  "format-check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build src/main.ts -o dist",
    "test": "jest",
    "all": "yarn clean && yarn build && yarn format && yarn lint && yarn package && yarn test"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.56.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
